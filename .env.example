# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
DEBUG=false
LOG_LEVEL=INFO

# Database (required for sessions and chat history)
DATABASE_URL=sqlite:///./ce_gpt.db
# Or PostgreSQL: postgresql://user:pass@host:5432/dbname

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=CE-GPT
QDRANT_API_KEY=

# Ollama / models
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b-it-qat
EMBEDDING_MODEL=embeddinggemma:latest
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Search / processing
BATCH_SIZE=32
MAX_WORKERS=4
TOP_K=50
TOP_K_RERANK=20
SIMILARITY_THRESHOLD=0.1
RERANK_THRESHOLD=0.5

# Session and chat history compression
SESSION_AUTO_CREATE=true
SESSION_MAX_MESSAGES=1000
CONTEXT_WINDOW_TOKENS=8192
CHAT_HISTORY_COMPRESSION_ENABLED=true
COMPRESSION_TRIGGER_AFTER_MESSAGES=10
COMPRESSION_INTERVAL=5
COMPRESSION_SUMMARY_MAX_TOKENS=2048
COMPRESSION_RECENT_MESSAGES_FULL=5

# Cache
CACHE_EMBEDDINGS_DIR=cache/embeddings
CACHE_CHUNKS_DIR=cache/chunks
CACHE_MAX_SIZE=1024
CACHE_TTL=3600
